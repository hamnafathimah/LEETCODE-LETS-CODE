class Solution:
    def findGCD(self, nums: List[int]) -> int:
        lowest=nums[0]
        highest=nums[0]
        for i in nums:
            if(i<lowest):
                lowest=i
            if(i>highest):
                highest=i
            large=1
            for j in range(1,lowest+1):
                if(highest%j==0 and lowest%j==0):
                    large=j
        return large                          
